NODE_ENV=development
PORT=5000
# Where the frontend lives — include the SPA base path (email links are
# built from this). Production: https://taplow04.github.io/gym-app
CLIENT_URL=http://localhost:5173/gym-app

# MongoDB Atlas connection string (include a database name, e.g. /forge)
MONGODB_URI=

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES_DAYS=30
JWT_REFRESH_EXPIRES_DAYS_SHORT=1

# Email-verification OTP (optional — these are the defaults)
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SEC=60

# Cloudinary — required for image uploads (dashboard → API Keys)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Brevo HTTPS API key (Brevo dashboard → SMTP & API → API Keys). Preferred
# in production: hosts like Render block outbound SMTP ports, the HTTPS API
# always works. When set, it takes priority over SMTP below.
BREVO_API_KEY=

# SMTP — leave empty in development to log emails to the console
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Forge <no-reply@forge.app>"
